
S3_ENDPOINT_URL=https://s3.example.com
S3_REGION=ru-1
S3_BUCKET=
S3_ACCESS_KEY=__CHANGE_ME__
S3_SECRET_KEY=__CHANGE_ME__
S3_AUDIO_KEY_PREFIX=tts/
S3_PUBLIC_URL_BASE=

# --- Redis (брокер/бэкенд Celery) --------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Kafka -------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_START=tts.start
KAFKA_TOPIC_MEDIA_UPLOAD=media.upload
MEDIA_OBJECT_TYPE=podcast_file_url

# --- Celery ------------------------------------------------------------------
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=200
CELERY_WORKER_MAX_MEMORY_PER_CHILD=900000
CELERY_RESULT_EXPIRES_SECONDS=3600

# --- Silero TTS --------------------------------------------------------------
# Голос по умолчанию. Допустимые: aidar, baya, kseniya, xenia, eugene
SILERO_DEFAULT_VOICE=aidar
# Каталог кэша моделей torch (по умолчанию ~/.cache/torch)
TORCH_HOME=/app/.cache/torch

# --- Прочее ------------------------------------------------------------------
AUDIO_DIR=/app/audio
LOG_LEVEL=INFO

OTEL_SERVICE_NAME=tts-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_PYTHON_LOGGING_AUTO_INSTRUMENTATION_ENABLED=true
DEPLOYMENT_ENV=dev
