# Настройки Redis (брокер Celery)
REDIS_URL=redis://redis:6379/0

# Настройки Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_REQUESTS=tts.requests
KAFKA_TOPIC_COMPLETED=tts.completed
KAFKA_TOPIC_FAILED=tts.failed

# Папка для сохранения аудиофайлов (внутри контейнера)
AUDIO_DIR=/app/audio

# Список доступных голосов через запятую
ALLOWED_VOICES=aidar,baya,kseniya,xenia,eugene

# Язык модели Silero
SILERO_LANGUAGE=ru