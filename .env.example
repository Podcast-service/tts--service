S3_ENDPOINT_URL=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_AUDIO_KEY_PREFIX=
# When a CNAME points at the bucket, set this to the public domain
# (e.g. https://bucket.castapp.ru) so generated URLs are clean: <base>/<key>.
S3_PUBLIC_URL_BASE=


KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_START=tts.start
KAFKA_TOPIC_MEDIA_UPLOAD=media.upload
MEDIA_OBJECT_TYPE=podcast_file_url

CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=200
CELERY_WORKER_MAX_MEMORY_PER_CHILD=900000
CELERY_RESULT_EXPIRES_SECONDS=3600

DEPLOYMENT_ENV=dev
