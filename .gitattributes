# Normalize all text files to LF in the repo.
# Windows working copies still get CRLF if core.autocrlf=true, but commits stay LF.
* text=auto eol=lf

# Files that MUST be LF (run inside Linux containers)
*.py    text eol=lf
*.sh    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
Dockerfile     text eol=lf
.dockerignore  text eol=lf
.gitignore     text eol=lf
.env.example   text eol=lf

# Binary — never touch
*.wav   binary
*.png   binary
*.jpg   binary
*.pt    binary
*.onnx  binary
